#ifndef ETHERNET_DHCP_H
#define ETHERNET_DHCP_H

#include <main.h>
#include <stdint.h>
#include <stdbool.h>

/* =========================================================================
   1. Network Constants & Ports
   ========================================================================= */
#define DHCP_SERVER_PORT            67
#define DHCP_CLIENT_PORT            68

// Magic Cookie (DHCP Signature: 0x63825363)
// Defined in Big Endian format for direct buffer comparison if needed
#define DHCP_MAGIC_COOKIE           0x63825363

/* =========================================================================
   2. DHCP Header Field Definitions (RFC 2131)
   ========================================================================= */

// --- Message Op Code (OP) ---
#define DHCP_OP_REQUEST             1       // Boot Request (Client to Server)
#define DHCP_OP_REPLY               2       // Boot Reply (Server to Client)

// --- Hardware Address Type (HTYPE) ---
#define DHCP_HTYPE_ETHERNET         1       // Ethernet (10Mb)
#define DHCP_HTYPE_IEEE802          6       // IEEE 802 Networks
#define DHCP_HTYPE_ARCNET           7       // ARCNET

// --- Hardware Address Length (HLEN) ---
#define DHCP_HLEN_ETHERNET          6       // Ethernet MAC length (6 bytes)

// --- BOOTP Flags ---
#define DHCP_FLAG_BROADCAST         0x8000  // Broadcast (Bit 15 set)
#define DHCP_FLAG_UNICAST           0x0000  // Unicast (Bit 15 cleared)

/* =========================================================================
   3. DHCP Options (RFC 2132)
   ========================================================================= */
// Structure: [CODE] [LEN] [VALUE]

// --- Basic Control ---
#define DHCP_OPT_PAD                0       // Pad Option
#define DHCP_OPT_END                255     // End Option

// --- Subnet & Router ---
#define DHCP_OPT_SUBNET_MASK        1       // Subnet Mask
#define DHCP_OPT_TIME_OFFSET        2       // Time Offset (from UTC)
#define DHCP_OPT_ROUTER             3       // Router (Gateway)
#define DHCP_OPT_TIME_SERVER        4       // Time Server (RFC 868)
#define DHCP_OPT_NAME_SERVER        5       // Name Server (IEN 116)
#define DHCP_OPT_DNS_SERVER         6       // Domain Name Server (DNS)
#define DHCP_OPT_LOG_SERVER         7       // Log Server
#define DHCP_OPT_COOKIE_SERVER      8       // Cookie Server
#define DHCP_OPT_LPR_SERVER         9       // LPR Server
#define DHCP_OPT_HOST_NAME          12      // Host Name
#define DHCP_OPT_BOOT_SIZE          13      // Boot File Size
#define DHCP_OPT_DOMAIN_NAME        15      // Domain Name

// --- Interface & IP Layer ---
#define DHCP_OPT_IP_TTL             23      // Default IP Time to Live
#define DHCP_OPT_MTU_AGING          24      // Path MTU Aging Timeout
#define DHCP_OPT_INTERFACE_MTU      26      // Interface MTU size
#define DHCP_OPT_BROADCAST_ADDR     28      // Broadcast Address
#define DHCP_OPT_NTP_SERVER         42      // Network Time Protocol (NTP) Servers
#define DHCP_OPT_WINS_SERVER        44      // NetBIOS over TCP/IP Name Server

// --- DHCP Extensions ---
#define DHCP_OPT_REQUESTED_IP       50      // Requested IP Address
#define DHCP_OPT_LEASE_TIME         51      // IP Address Lease Time
#define DHCP_OPT_OPTION_OVERLOAD    52      // Option Overload
#define DHCP_OPT_MSG_TYPE           53      // DHCP Message Type (Discover, Offer...)
#define DHCP_OPT_SERVER_ID          54      // Server Identifier
#define DHCP_OPT_PARAM_LIST         55      // Parameter Request List
#define DHCP_OPT_MESSAGE            56      // Message
#define DHCP_OPT_MAX_MSG_SIZE       57      // Maximum DHCP Message Size
#define DHCP_OPT_RENEWAL_TIME       58      // Renewal (T1) Time Value
#define DHCP_OPT_REBINDING_TIME     59      // Rebinding (T2) Time Value
#define DHCP_OPT_VENDOR_CLASS_ID    60      // Vendor Class Identifier
#define DHCP_OPT_CLIENT_ID          61      // Client-identifier
#define DHCP_OPT_TFTP_SERVER        66      // TFTP Server Name
#define DHCP_OPT_BOOTFILE           67      // Bootfile Name

// --- DHCP Message Types (Values for Option 53) ---
#define DHCP_MSG_DISCOVER           1
#define DHCP_MSG_OFFER              2
#define DHCP_MSG_REQUEST            3
#define DHCP_MSG_DECLINE            4
#define DHCP_MSG_ACK                5
#define DHCP_MSG_NAK                6
#define DHCP_MSG_RELEASE            7
#define DHCP_MSG_INFORM             8

#define DHCP_TIMEOUT_MS			 4000    // 4 seconds

/* =========================================================================
   4. DHCP Packet Structure
   ========================================================================= */

// Ensure 1-byte alignment for the struct to match network packet format
#pragma pack(push, 1)

typedef struct {
    uint8_t  op;            // 0: Message opcode/type
    uint8_t  htype;         // 1: Hardware addr type
    uint8_t  hlen;          // 2: Hardware addr length
    uint8_t  hops;          // 3: Relay agent hops
    uint32_t xid;           // 4: Transaction ID (Random)
    uint16_t secs;          // 8: Seconds since boot
    uint16_t flags;         // 10: Flags
    uint32_t ciaddr;        // 12: Client IP address
    uint32_t yiaddr;        // 16: Your (client) IP address
    uint32_t siaddr;        // 20: Next server IP address
    uint32_t giaddr;        // 24: Relay agent IP address
    uint8_t  chaddr[16];    // 28: Client hardware address (MAC) + Padding
    uint8_t  sname[64];     // 44: Server host name
    uint8_t  file[128];     // 108: Boot file name
    uint32_t magic_cookie;  // 236: Magic cookie (0x63825363)
    uint8_t  options[0];    // 240: Flexible Array Member (Start of Options)
} dhcp_packet_t;

#pragma pack(pop)

// Fixed size of the header before options start
#define DHCP_FIXED_LEN sizeof(dhcp_packet_t)


/* =========================================================================
   5. Helper Macros for Endianness (Host to Network)
   ========================================================================= */
// The W5500 expects Big Endian. If your MCU is Little Endian (ARM/STM32/ESP),
// you must swap bytes for multi-byte types (uint16_t, uint32_t).

#include "cmsis_gcc.h"

static inline uint32_t htonl(uint32_t x) { return __REV(x); }
static inline uint32_t ntohl(uint32_t x) { return __REV(x); }
static inline uint16_t htons(uint16_t x) { return __REV16(x); }
static inline uint16_t ntohs(uint16_t x) { return __REV16(x); }


#include <string.h>

typedef enum {
    DHCP_IDLE,
    DHCP_SEND_DISCOVER,
    DHCP_WAIT_OFFER,
    DHCP_SEND_REQUEST,
    DHCP_WAIT_ACK,
    DHCP_BOUND,
    DHCP_ERROR
} DHCP_State_t;


typedef struct {
    DHCP_State_t state;
    uint32_t xid;
    uint32_t lease_time;
    uint32_t t_start;

    uint8_t offered_ip[4];
    uint8_t server_id[4];
    uint8_t subnet[4];
    uint8_t gateway[4];

    bool offer_received;
    bool ack_received;

    uint8_t socket;
} DHCP_Control_t;



uint16_t build_dhcp_discover(uint8_t * buffer, uint8_t *mac_addr, uint32_t xid, char * hostname);
uint16_t build_dhcp_request(uint8_t * buffer, uint8_t *mac_addr, uint32_t xid, uint8_t * offered_ip, uint8_t * server_id, char * hostname);
bool dhcp_timeout(DHCP_Control_t *dhcp, uint32_t timeout_ms);
bool dhcp_T1_expired(DHCP_Control_t *dhcp);
bool dhcp_T2_expired(DHCP_Control_t *dhcp);
bool dhcp_lease_expired(DHCP_Control_t *dhcp);
uint8_t DHCP_Parse_Response(uint8_t *buffer, uint16_t len, uint32_t expected_xid, DHCP_Control_t *dhcp_ctrl);

#endif /* ETHERNET_DHCP_H */
