		}
		imr = current_imr | imr;
	}

	drv->tx[0] = (W5500_COMMON_IMR >> 8) & 0xFF;
	drv->tx[1] = W5500_COMMON_IMR & 0xFF;
	drv->tx[2] = W5500_BSB_COMMON | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	drv->tx[3] = imr;

	W5500_Transmit(drv, drv->tx, 4);

	return HAL_OK;
}

