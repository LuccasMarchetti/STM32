#include "ethernet_mdns.h"
#include <string.h>
#include <stdio.h>

MDNS_Request_Type mdns_parse_query(uint8_t *buf, uint16_t len, const char *hostname, uint8_t *my_ip) {
    if (len < 12) return MDNS_IGNORE;

    // Verifica Flags (QR deve ser 0 para requisição)
    if ((buf[2] & 0x80) != 0) return MDNS_IGNORE;

    // Verifica se há pelo menos 1 pergunta
    if (buf[4] != 0x00 || buf[5] == 0x00) return MDNS_IGNORE;

    uint8_t *ptr = buf + 12;

    // --- LÓGICA 1: É uma pergunta pelo nosso HOSTNAME? ---
    uint8_t expected_len = strlen(hostname);
    if (*ptr == expected_len && memcmp(ptr + 1, hostname, expected_len) == 0) {
        // Pula o hostname
        uint8_t *temp_ptr = ptr + 1 + expected_len;
        // Verifica o "local"
        if (*temp_ptr == 5 && memcmp(temp_ptr + 1, "local", 5) == 0) {
            temp_ptr += 6; // Pula o "local"
            if (*temp_ptr == 0x00) { // Fim da string
                temp_ptr++;
                uint16_t qtype = (temp_ptr[0] << 8) | temp_ptr[1];

                // Tipo A (0x01) ou ANY (0xFF)
                if (qtype == 0x0001 || qtype == 0x00FF) {
                    return MDNS_REQ_A;
                }
            }
        }
    }

    // --- LÓGICA 2: É uma pergunta pelo nosso IP (Reverse Lookup)? ---
    // O formato esperado é: <ip4>.<ip3>.<ip2>.<ip1>.in-addr.arpa
    // Ex: para 192.168.1.50 -> 50.1.168.192.in-addr.arpa

    // Para simplificar no C, montamos uma string temporária com o formato invertido esperado
    char reverse_ip_str[32];
    sprintf(reverse_ip_str, "%d.%d.%d.%d.in-addr.arpa", my_ip[3], my_ip[2], my_ip[1], my_ip[0]);

    // Como o DNS usa Length-Prefixed, vamos criar um buffer com o formato DNS dessa string invertida
    uint8_t expected_ptr_name[64];
    uint8_t *build_ptr = expected_ptr_name;
    char *token = strtok(reverse_ip_str, ".");

    while (token != NULL) {
        uint8_t t_len = strlen(token);
        *build_ptr++ = t_len;
        memcpy(build_ptr, token, t_len);
        build_ptr += t_len;
        token = strtok(NULL, ".");
    }
    *build_ptr++ = 0x00; // Terminador Nulo

    uint16_t expected_ptr_len = build_ptr - expected_ptr_name;

    // Compara o nome recebido no pacote com o nome reverso que acabamos de montar
    if (len >= 12 + expected_ptr_len) {
        if (memcmp(ptr, expected_ptr_name, expected_ptr_len) == 0) {
            uint8_t *type_ptr = ptr + expected_ptr_len;
            uint16_t qtype = (type_ptr[0] << 8) | type_ptr[1];

            // Tipo PTR (0x0C) ou ANY (0xFF)
            if (qtype == 0x000C || qtype == 0x00FF) {
                return MDNS_REQ_PTR;
            }
        }
    }

    return MDNS_IGNORE;
}

// Converte "hostname.local" para o formato DNS: "\x08hostname\x05local\x00"
uint8_t* format_mdns_name(uint8_t *buffer, const char *hostname) {
    uint8_t len = strlen(hostname);

    *buffer++ = len; // Tamanho do hostname
    memcpy(buffer, hostname, len);
    buffer += len;

    const char *local = "local";
    *buffer++ = 5;   // Tamanho da palavra "local"
    memcpy(buffer, local, 5);
    buffer += 5;

    *buffer++ = 0;   // Fim da string (Null terminator do DNS)
    return buffer;
}

uint16_t build_mdns_response_A(uint8_t *buffer, const char *hostname, uint8_t *my_ip) {
    uint8_t *ptr = buffer;

    // 1. Cabeçalho (12 bytes)
    *ptr++ = 0x00; *ptr++ = 0x00; // Transaction ID: 0
    *ptr++ = 0x84; *ptr++ = 0x00; // Flags: Standard Query Response, No error
    *ptr++ = 0x00; *ptr++ = 0x00; // Questions: 0
    *ptr++ = 0x00; *ptr++ = 0x01; // Answers: 1
    *ptr++ = 0x00; *ptr++ = 0x00; // Authority: 0
    *ptr++ = 0x00; *ptr++ = 0x00; // Additional: 0

    // 2. Nome do Dispositivo (ex: stm32g0.local)
    ptr = format_mdns_name(ptr, hostname);

    // 3. Informações do Registro (Type, Class, TTL, Length)
    *ptr++ = 0x00; *ptr++ = 0x01; // Type: A (Host Address)
    *ptr++ = 0x80; *ptr++ = 0x01; // Class: IN + Cache Flush

    *ptr++ = 0x00; *ptr++ = 0x00; // TTL (4 bytes): 120 segundos
    *ptr++ = 0x00; *ptr++ = 0x78;

    *ptr++ = 0x00; *ptr++ = 0x04; // Data Length: 4 bytes (IPv4)

    // 4. O seu endereço IP!
    memcpy(ptr, my_ip, 4);
    ptr += 4;

    // Retorna o tamanho total do pacote para você passar pro W5500_SocketSend
    return (uint16_t)(ptr - buffer);
}

// Converte IP [192, 168, 1, 50] para "\x0250\x011\x03168\x03192\x07in-addr\x04arpa\x00"
uint8_t* format_mdns_reverse_ip(uint8_t *buffer, uint8_t *ip) {
    char temp_str[4];

    // Faz o loop de trás pra frente (ip[3], ip[2], ip[1], ip[0])
    for (int i = 3; i >= 0; i--) {
        sprintf(temp_str, "%d", ip[i]); // Converte o número (ex: 50) para string ("50")
        uint8_t len = strlen(temp_str);

        *buffer++ = len; // Tamanho do número
        memcpy(buffer, temp_str, len); // Copia a string do número
        buffer += len;
    }

    // Adiciona o domínio final: "in-addr.arpa"
    *buffer++ = 7; // Tamanho de "in-addr"
    memcpy(buffer, "in-addr", 7);
    buffer += 7;

    *buffer++ = 4; // Tamanho de "arpa"
    memcpy(buffer, "arpa", 4);
    buffer += 4;

    *buffer++ = 0x00; // Fim da string DNS

    return buffer;
}

uint16_t build_mdns_response_PTR(uint8_t *buffer, const char *hostname, uint8_t *my_ip) {
    uint8_t *ptr = buffer;

    // 1. Cabeçalho (12 bytes) - Igual ao Tipo A
    *ptr++ = 0x00; *ptr++ = 0x00; // Transaction ID: 0
    *ptr++ = 0x84; *ptr++ = 0x00; // Flags: Standard Query Response, Authoritative
    *ptr++ = 0x00; *ptr++ = 0x00; // Questions: 0
    *ptr++ = 0x00; *ptr++ = 0x01; // Answers: 1
    *ptr++ = 0x00; *ptr++ = 0x00; // Authority: 0
    *ptr++ = 0x00; *ptr++ = 0x00; // Additional: 0

    // 2. O Nome (O IP invertido: ex. 50.1.168.192.in-addr.arpa)
    ptr = format_mdns_reverse_ip(ptr, my_ip);

    // 3. Informações do Registro (Type, Class, TTL, Length)
    *ptr++ = 0x00; *ptr++ = 0x0C; // Type: PTR (Pointer - Valor 12)
    *ptr++ = 0x80; *ptr++ = 0x01; // Class: IN + Cache Flush

    *ptr++ = 0x00; *ptr++ = 0x00; // TTL (4 bytes): 120 segundos
    *ptr++ = 0x00; *ptr++ = 0x78;

    // O "Data Length" no PTR é o tamanho da string do hostname formatada em DNS.
    // A matemática é: tamanho do nome + 1 (byte do len do nome) + 6 (byte len de "local" + palavra "local") + 1 (byte zero) = strlen + 8.
    uint16_t name_len = strlen(hostname) + 8;

    *ptr++ = (name_len >> 8) & 0xFF; // High byte do Data Length
    *ptr++ = name_len & 0xFF;        // Low byte do Data Length

    // 4. Os Dados! (O nome real do dispositivo: ex. stm32g0.local)
    // Reutilizamos a sua função existente!
    ptr = format_mdns_name(ptr, hostname);

    // Retorna o tamanho total do pacote
    return (uint16_t)(ptr - buffer);
}
