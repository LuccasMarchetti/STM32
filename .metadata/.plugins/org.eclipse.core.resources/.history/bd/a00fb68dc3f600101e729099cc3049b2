	w5500->tx[0] = (W5500_COMMON_IMR >> 8) & 0xFF;
	w5500->tx[1] = W5500_COMMON_IMR & 0xFF;
	w5500->tx[2] = W5500_BSB_COMMON | W5500_RWB_READ | W5500_OPCODE_VDM;

	if (W5500_Receive(w5500, w5500->tx, w5500->rx, 4) != HAL_OK) {
		return HAL_ERROR;
	}

	imr = &w5500->rx[3];

	return HAL_OK;
}

HAL_StatusTypeDef W5500_ConfigureCommonIMR(W5500_HandleTypeDef * w5500, uint8_t imr, bool clear) {

	if (!clear) {
		uint8_t current_imr;
		if (W5500_ReadCommonIMR(w5500, &current_imr) != HAL_OK) {
			return HAL_ERROR;
		}
		imr = current_imr | imr;
	}
	w5500->tx[0] = (W5500_COMMON_IMR >> 8) & 0xFF;
	w5500->tx[1] = W5500_COMMON_IMR & 0xFF;
	w5500->tx[2] = W5500_BSB_COMMON | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = imr;

	return W5500_Transmit(w5500, w5500->tx, 4);
}

