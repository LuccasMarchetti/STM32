08001a6c <dhcp_lease_expired>:
	if (dhcp->lease_time == 0) return true; // Lease expirado
	if (dhcp->lease_time > UINT32_MAX/1000) dhcp->lease_time = UINT32_MAX/1000; // Proteção contra overflow
	return (HAL_GetTick() - dhcp->t_start) > (dhcp->lease_time * 1000 * 0.875); // Considera expirado quando chegar em 87.5% do tempo de lease, para renovar com antecedência
}

