HAL_StatusTypeDef W5500_SocketSend(
	W5500_Driver_t *drv,
	uint8_t socket,
	uint8_t *data,
	uint16_t size
) {
	uint16_t tx_wr;
	uint16_t offset;

	// Read TX Write Pointer
	W5500_ReadSnTXWR(drv, socket, &tx_wr);

	// Calculate offset address
	offset = tx_wr & drv->hw_sockets[socket].tx_mask;

	drv->tx[0] = (offset >> 8) & 0xFF;
	drv->tx[1] = offset & 0xFF;
	drv->tx[2] = W5500_BSB_SOCKET_TX(socket) | W5500_RWB_WRITE | W5500_OPCODE_VDM;

	memcpy(&drv->tx[3], data, size);

	W5500_Transmit(drv, drv->tx, 3 + size);

	// Update TX Write Pointer
	tx_wr += size;
	W5500_WriteSnTXWR(drv, socket, tx_wr);

	W5500_WriteSnCR(drv, socket, W5500_Sn_CR_SEND);

	return HAL_OK;
}

HAL_StatusTypeDef W5500_SocketRecv(
    W5500_Driver_t *drv,
    uint8_t socket,
    uint8_t *out,
    uint16_t max_len,
    uint16_t *out_len
) {
    uint16_t rx_size;
    uint16_t rx_rd;
    uint16_t offset;

    W5500_ReadSnRXRSR(drv, socket, &rx_size);

    if (rx_size == 0) {
        *out_len = 0;
        return HAL_OK;
    }

    if (rx_size > max_len)
        rx_size = max_len;

    W5500_ReadSnRXRD(drv, socket, &rx_rd);

    offset = rx_rd & drv->hw_sockets[socket].rx_mask;

    drv->tx[0] = (offset >> 8) & 0xFF;
    drv->tx[1] = offset & 0xFF;
    drv->tx[2] = W5500_BSB_SOCKET_RX(socket) |
                 W5500_RWB_READ |
                 W5500_OPCODE_VDM;

    W5500_Receive(drv, drv->tx, drv->rx, 3 + rx_size);

    memcpy(out, &drv->rx[3], rx_size);

    rx_rd += rx_size;
    W5500_WriteSnRXRD(drv, socket, rx_rd);

    W5500_WriteSnCR(drv, socket, W5500_Sn_CR_RECV);

    *out_len = rx_size;
    return HAL_OK;
}

static void W5500_SocketFSM_Opening(W5500_Driver_t *drv, NetSocket_t *s)
{
    switch (s->hw_state) {

    case W5500_SOCK_CLOSED:
        // Criar socket
        s->id = W5500_OpenSocket(drv, s->type, s->source_port);
        break;

    case W5500_SOCK_INIT:
        if (s->type == SOCKET_TCP) {
        	if (s->tcp_role == TCP_ROLE_SERVER) {
        		W5500_WriteSnCR(drv, s->id, W5500_Sn_CR_LISTEN);
			}
			else if (s->tcp_role == TCP_ROLE_CLIENT) {
				W5500_WriteSnCR(drv, s->id, W5500_Sn_CR_CONNECT);
			}
        } else {
            // UDP e MACRAW já estão prontos
            s->state = SOCKET_READY;
        }
        break;

    case W5500_SOCK_LISTEN:
        // Aguardando conexão
        break;

    case W5500_SOCK_ESTABLISHED:
    case W5500_SOCK_UDP:
    case W5500_SOCK_MACRAW:
        s->state = SOCKET_READY;
        break;

    default:
        break;
    }
}

static void W5500_SocketFSM_Ready(W5500_Driver_t *drv, NetSocket_t *s)
{
    switch (s->hw_state) {

    case W5500_SOCK_ESTABLISHED:
    case W5500_SOCK_UDP:
    case W5500_SOCK_MACRAW:

        if (s->rx_pending) {
        	W5500_SocketRecv(drv, s->id, s->rx_buf, 1024, &s->rx_len);
            s->rx_pending = false;
        }

        if (s->tx_pending) {
            W5500_SocketSend(drv, s->id, s->tx_buf, s->tx_len);
			s->tx_pending = false;
			s->tx_len = 0;
        }
        break;

    case W5500_SOCK_CLOSEWAIT:
        s->state = SOCKET_CLOSING;
        break;

    case W5500_SOCK_CLOSED:
        s->state = SOCKET_UNUSED;
        break;

    default:
        break;
    }
}

static void W5500_SocketFSM_Closing(W5500_Driver_t *drv, NetSocket_t *s)
{
    switch (s->hw_state) {

    case W5500_SOCK_CLOSEWAIT:
    	W5500_WriteSnCR(drv, s->id, W5500_Sn_CR_CLOSE);
        break;

    case W5500_SOCK_FINWAIT:
    case W5500_SOCK_LASTACK:
    case W5500_SOCK_TIMEWAIT:
        // Aguardando fechamento completo
        break;

    case W5500_SOCK_CLOSED:
        s->state = SOCKET_UNUSED;
        break;

    default:
        break;
    }
}

static void W5500_SocketFSM_Error(W5500_Driver_t *drv, NetSocket_t *s)
{
    // Força fechamento para recuperar
	W5500_WriteSnCR(drv, s->id, W5500_Sn_CR_CLOSE);
    s->state = SOCKET_UNUSED;
}

void W5500_SocketFSM(W5500_Driver_t *drv, NetSocket_t *s)
{

    if(!W5500_ReadSnSR(drv, s->id, &s->hw_state)) {
    	s->state = SOCKET_ERROR;
		return;
	}

    if (s->hw_state == W5500_SOCK_ESTABLISHED ||
        s->hw_state == W5500_SOCK_UDP ||
        s->hw_state == W5500_SOCK_MACRAW)
    {
        s->state = SOCKET_READY;
    }

    if (s->hw_state == W5500_SOCK_CLOSEWAIT) {
        s->state = SOCKET_CLOSING;
    }

    if (s->hw_state == W5500_SOCK_CLOSED) {
        s->state = SOCKET_UNUSED;
    }


    switch (s->state) {

    case SOCKET_UNUSED:
        // Socket não alocado
        break;

    case SOCKET_OPENING:
        W5500_SocketFSM_Opening(drv, s);
        break;

    case SOCKET_READY:
    	W5500_SocketFSM_Ready(drv, s);
        break;

    case SOCKET_CLOSING:
    	W5500_SocketFSM_Closing(drv, s);
        break;

    case SOCKET_ERROR:
    	W5500_SocketFSM_Error(drv, s);
        break;
    }
}

void DHCP_FSM(W5500_Driver_t *drv)
{
    DHCP_Control_t *dhcp = &drv->dhcp;

    switch (dhcp->state) {

    // ------------------------------------------------
    case DHCP_IDLE:
        dhcp->socket = 0xFF;
        dhcp->state = DHCP_SEND_DISCOVER;
        break;

    // ------------------------------------------------
    case DHCP_SEND_DISCOVER:
        DHCP_SendDiscover(drv);
        dhcp->t_start = HAL_GetTick();
        dhcp->state = DHCP_WAIT_OFFER;
        break;

    // ------------------------------------------------
    case DHCP_WAIT_OFFER:
        if (dhcp->offer_received) {
        	dhcp->offer_received = false;
            dhcp->offered_ip = dhcp_get_offered_ip(drv);
            dhcp->server_id  = dhcp_get_server_id(drv);

            dhcp->state = DHCP_SEND_REQUEST;
        }
        else if (dhcp_timeout(dhcp->t_start, DHCP_TIMEOUT_MS)) {
            dhcp->state = DHCP_SEND_DISCOVER; // retry
        }
        break;

    // ------------------------------------------------
    case DHCP_SEND_REQUEST:
        DHCP_SendRequest(drv);
        dhcp->t_start = HAL_GetTick();
        dhcp->state = DHCP_WAIT_ACK;
        break;

    // ------------------------------------------------
    case DHCP_WAIT_ACK:
        if (dhcp->ack_received) {
        	dhcp->ack_received = false;
            drv->IP[0]      = dhcp->offered_ip >> 24;
            drv->IP[1]      = (dhcp->offered_ip >> 16) & 0xFF;
            drv->IP[2]      = (dhcp->offered_ip >> 8) & 0xFF;
            drv->IP[3]      = dhcp->offered_ip & 0xFF;
            drv->GATEWAY = dhcp_get_gateway(drv);
            drv->SUBNET  = dhcp_get_subnet(drv);

            dhcp->lease_time = dhcp_get_lease_time(drv);
            dhcp->t_start    = HAL_GetTick();

            dhcp->state = DHCP_BOUND;
        }
        else if (dhcp_timeout(dhcp->t_start, DHCP_TIMEOUT_MS)) {
            dhcp->state = DHCP_SEND_DISCOVER;
        }
        break;

    // ------------------------------------------------
    case DHCP_BOUND:
        // Aqui o IP é válido

        // Futuro: renew em T1 = lease_time / 2
        break;

    // ------------------------------------------------
    case DHCP_ERROR:
        // Fecha socket, limpa estado, aguarda retry externo
        break;

    default:
        dhcp->state = DHCP_ERROR;
        break;
    }
}

void DHCP_HandleRx(W5500_Driver_t *drv, uint8_t *buf, uint16_t len)
{
    DHCP_Control_t *dhcp = &drv->dhcp;

    uint8_t msg = DHCP_Parse_Response(
        buf,
        len,
        dhcp->xid,
        dhcp
    );

    switch (msg) {

    case DHCP_MSG_OFFER:
        dhcp->offer_received = true;
        break;

    case DHCP_MSG_ACK:
        dhcp->ack_received = true;
        break;

    case DHCP_MSG_NAK:
        dhcp->state = DHCP_SEND_DISCOVER;
        break;

    default:
        break;
    }
}

void DHCP_SendRequest(W5500_Driver_t *drv)
{
    DHCP_Control_t *dhcp = &drv->dhcp;

    uint16_t len = build_dhcp_request(
        drv->tx,
        drv->MAC,
        dhcp->xid,
        dhcp->offered_ip,
        dhcp->server_id
    );

    W5500_SocketSend(drv, dhcp->socket, drv->tx, len);
}

void DHCP_SendDiscover(W5500_Driver_t *drv) {
    // Abre o socket APENAS se ainda não estiver aberto
    if (drv->dhcp.socket == 0xFF) {
    	drv->dhcp.socket = W5500_OpenSocket(drv, W5500_Sn_MR_UDP, DHCP_CLIENT_PORT);
    }

    // Configura destino (Broadcast)
    uint8_t dest_ip[4] = {255, 255, 255, 255};
    uint8_t dest_mac[6] = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};
    W5500_SetSocketDestIP(drv, drv->dhcp.socket, dest_ip);
    W5500_SetSocketDestPort(drv, drv->dhcp.socket, DHCP_SERVER_PORT);
    W5500_SetSocketDestMAC(drv, drv->dhcp.socket, dest_mac);

    // Gera XID novo
    drv->dhcp.xid = HAL_GetTick(); // Usar tick como semente simples

    // Monta e Envia
    uint16_t len = build_dhcp_discover(&drv->tx[0], drv->MAC, drv->dhcp.xid);
    W5500_SocketSend(drv, drv->dhcp.socket, &drv->tx[0], len);
}

// Retorna true se recebeu o pacote esperado
bool DHCP_CheckResponse(W5500_Driver_t *drv, uint8_t expected_msg_type) {
    uint16_t len = 0;

    // Verifica se tem dados no socket DHCP
    W5500_SocketRecv(drv, drv->dhcp.socket, drv->rx, 2048, &len);

    if (len > 0) {
        uint8_t msg = DHCP_Parse_Response(drv->rx, len, drv->dhcp.xid, &drv->dhcp);
        if (msg == expected_msg_type) {
            return true;
        }
    }
    return false;
}

void w5500_NetworkManagerTask(void *argument) {
	void W5500_NetTask(void *arg) {
	    W5500_Driver_t *drv = arg;

	    for (;;) {
	        uint32_t flags = osEventFlagsWait(
	            drv->EventHandle,
	            EVT_W5500_IRQ | EVT_NET_TICK | EVT_APP_REQUEST,
	            osFlagsWaitAny,
	            100
	        );

	        if (flags & EVT_NET_TICK) {
	            DHCP_FSM(drv);
	        }

	        if (flags & EVT_W5500_IRQ) {
	            W5500_HandleIRQ(drv);
	        }

	        if (flags & EVT_APP_REQUEST) {
	            Net_HandleAppRequests(drv);
	        }
	    }
	}


HAL_StatusTypeDef W5500_Init(W5500_Driver_t * drv) {
	W5500_Reset(drv);
	W5500_ReadVERSIONR(drv);
	W5500_GenerateMAC(drv);
	W5500_SetMAC(drv);
	W5500_ReadMAC(drv, drv->MAC);
	W5500_SetIP(drv);
	W5500_SetGATEWAY(drv);
	W5500_SetSUBNET(drv);
	W5500_PHYReset(drv);

	const osEventFlagsAttr_t interruptEvent_attributes = {
	  .name = "w5500Event",
	  .cb_mem = drv->interruptEventControlBlock,
	  .cb_size = sizeof(drv->interruptEventControlBlock),
	};
	drv->interruptEventHandle = osEventFlagsNew(&interruptEvent_attributes);

	return HAL_OK;
}
