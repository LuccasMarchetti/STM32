	drv->tx[2] = W5500_Sn_DIPR | W5500_RWB_WRITE | W5500_OPCODE_VDM;

	memcpy(&drv->tx[3], ip, 4);
	memcpy(&drv->sockets[socket].remote_ip, ip, 4);

	W5500_Transmit(drv, drv->tx, 7);

	return HAL_OK;
}

