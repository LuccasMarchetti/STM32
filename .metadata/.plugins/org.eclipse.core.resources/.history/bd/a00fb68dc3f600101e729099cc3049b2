HAL_StatusTypeDef W5500_ReleaseSemaphore(W5500_HandleTypeDef * w5500) {
	// Release I2C semaphore
	return osSemaphoreRelease(w5500->spiSemaphore);
}

HAL_StatusTypeDef W5500_Transmit(W5500_HandleTypeDef * w5500, uint8_t * cmd, uint16_t size) {
	HAL_StatusTypeDef ret;
	osSemaphoreAcquire(w5500->spiSemaphore, osWaitForever);

	ret = HAL_SPI_Transmit_DMA(w5500->hspi, cmd, size);

	osSemaphoreAcquire(w5500->spiSemaphore, osWaitForever); // Wait for transmission to complete
	osSemaphoreRelease(w5500->spiSemaphore); // Release semaphore
	return ret;
}

HAL_StatusTypeDef W5500_Receive(W5500_HandleTypeDef * w5500, uint8_t * cmd, uint8_t * data, uint16_t size) {
	HAL_StatusTypeDef ret;
	osSemaphoreAcquire(w5500->spiSemaphore, osWaitForever);

	ret = HAL_SPI_TransmitReceive_DMA(w5500->hspi, cmd, data, size);

	osSemaphoreAcquire(w5500->spiSemaphore, osWaitForever); // Wait for reception to complete
	osSemaphoreRelease(w5500->spiSemaphore); // Release semaphore
	return ret;
}

HAL_StatusTypeDef W5500_Setup(W5500_HandleTypeDef * w5500){

	if (w5500->hspi == NULL || w5500->spiSemaphore == NULL) {
		return HAL_ERROR;
	}

	return HAL_OK;
}

HAL_StatusTypeDef W5500_Reset(W5500_HandleTypeDef * w5500) {

	w5500->tx[0] = (W5500_COMMON_MR >> 8) & 0xFF;
	w5500->tx[1] = W5500_COMMON_MR & 0xFF;
	w5500->tx[2] = W5500_BSB_COMMON | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = W5500_COMMON_MR_RST;

	return W5500_Transmit(w5500, w5500->tx, 4);
}

HAL_StatusTypeDef W5500_PHYReset(W5500_HandleTypeDef * w5500) {

	w5500->tx[0] = (W5500_COMMON_PHYCFGR >> 8) & 0xFF;
	w5500->tx[1] = W5500_COMMON_PHYCFGR & 0xFF;
	w5500->tx[2] = W5500_BSB_COMMON | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = W5500_COMMON_PHYCFGR_OPMD_OPMDC | W5500_COMMON_PHYCFGR_ALL_CAPABLE_AUTO_NEGOTIATION_ENABLED;

	W5500_Transmit(w5500, w5500->tx, 4);

	w5500->tx[0] = (W5500_COMMON_PHYCFGR >> 8) & 0xFF;
	w5500->tx[1] = W5500_COMMON_PHYCFGR & 0xFF;
	w5500->tx[2] = W5500_BSB_COMMON | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = W5500_COMMON_PHYCFGR_RST | W5500_COMMON_PHYCFGR_OPMD_OPMDC | W5500_COMMON_PHYCFGR_ALL_CAPABLE_AUTO_NEGOTIATION_ENABLED;

	return W5500_Transmit(w5500, w5500->tx, 4);
}

HAL_StatusTypeDef W5500_ReadVERSIONR(W5500_HandleTypeDef * w5500) {

	w5500->tx[0] = (W5500_COMMON_VERSIONR >> 8) & 0xFF;
	w5500->tx[1] = W5500_COMMON_VERSIONR & 0xFF;
	w5500->tx[2] = W5500_BSB_COMMON | W5500_RWB_READ | W5500_OPCODE_VDM;

	W5500_Receive(w5500, w5500->tx, w5500->rx, 4);

	if (w5500->rx[3] != W5500_COMMON_VERSIONR_VALUE) {
		return HAL_ERROR;
	}
	w5500->versionr = w5500->rx[3];
	return HAL_OK;
}

HAL_StatusTypeDef W5500_GenerateMAC(W5500_HandleTypeDef * w5500){
	// Get Unique ID for generate MAC Address
	uint32_t uid[3];
	uid[0] = HAL_GetUIDw0();
	uid[1] = HAL_GetUIDw1();
	uid[2] = HAL_GetUIDw2();

	// Generate MAC Hash from UID
	uint32_t mac_hash = uid[0] ^ uid[1] ^ uid[2];

	w5500->MAC[0] = 0x02; // 0x02 = Locally Administered & Unicast
	w5500->MAC[1] = uid[0]  & 0xFF;
	w5500->MAC[2] = (mac_hash >> 24) & 0xFF;
	w5500->MAC[3] = (mac_hash >> 16) & 0xFF;
	w5500->MAC[4] = (mac_hash >> 8)  & 0xFF;
	w5500->MAC[5] = (mac_hash >> 0)  & 0xFF;
	return HAL_OK;
}

HAL_StatusTypeDef W5500_SetMAC(W5500_HandleTypeDef * w5500) {

	w5500->tx[0] = (W5500_COMMON_SHAR >> 8) & 0xFF;
	w5500->tx[1] = W5500_COMMON_SHAR & 0xFF;
	w5500->tx[2] = W5500_BSB_COMMON | W5500_RWB_WRITE | W5500_OPCODE_VDM;

	memcpy(&w5500->tx[3], w5500->MAC, W5500_COMMON_SHAR_LEN);

	return W5500_Transmit(w5500, w5500->tx, 3 + W5500_COMMON_SHAR_LEN);
}

