	return HAL_OK;
}

HAL_StatusTypeDef W5500_ReadUnreachIPPort(W5500_HandleTypeDef * w5500, uint8_t * ip, uint8_t * port) {
	w5500->tx[0] = (W5500_COMMON_UIPR >> 8) & 0xFF;
	w5500->tx[1] = W5500_COMMON_UIPR(socket) & 0xFF;
	w5500->tx[2] = W5500_BSB_COMMON | W5500_RWB_READ | W5500_OPCODE_VDM;

	if (W5500_Receive(w5500, w5500->tx, w5500->rx, 3 + W5500_COMMON_UIPR_LEN + W5500_COMMON_UPORTR_LEN) != HAL_OK) {
		return HAL_ERROR;
	}
	memcpy(ip, &w5500->rx[3], W5500_COMMON_UIPR_LEN);
	memcpy(port, &w5500->rx[3 + W5500_COMMON_UIPR_LEN], W5500_COMMON_UPORTR_LEN);

	return HAL_OK;
}


uint8_t W5500_OpenSocket(W5500_HandleTypeDef * w5500, uint8_t protocol, uint16_t port) {

	uint8_t socket = 0;

	if (protocol == W5500_Sn_MR_MACRAW) {
		socket = 0;
	} else {
		for (socket = W5500_MAX_SOCKETS-1; socket > 0 ; socket--) {
			if ((w5500->used_sockets & (1 << socket)) == 0) {
				w5500->used_sockets |= (1 << socket);
				break;
			}
		}
	}

	w5500->tx[0] = (W5500_BSB_SOCKET_REG(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_REG(socket) & 0xFF;
	w5500->tx[2] = W5500_Sn_MR | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = protocol;

	w5500->socket_cfg[socket].mode = protocol;

	W5500_Transmit(w5500, w5500->tx, 4);

	w5500->tx[0] = (W5500_BSB_SOCKET_REG(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_REG(socket) & 0xFF;
	w5500->tx[2] = W5500_Sn_CR | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = W5500_Sn_CR_OPEN;

	W5500_Transmit(w5500, w5500->tx, 4);

	w5500->socket_cfg[socket].source_port[0] = port >> 8;
	w5500->socket_cfg[socket].source_port[1] = port & 0xFF;

	w5500->tx[0] = (W5500_BSB_SOCKET_REG(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_REG(socket) & 0xFF;
	w5500->tx[2] = W5500_Sn_PORT | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = (w5500->socket_cfg[socket].source_port[0] >> 8) & 0xFF;
	w5500->tx[4] = w5500->socket_cfg[socket].source_port[1] & 0xFF;

	W5500_Transmit(w5500, w5500->tx, 5);

	return socket;
}

HAL_StatusTypeDef W5500_CloseSocket(W5500_HandleTypeDef * w5500, uint8_t socket) {

	w5500->tx[0] = (W5500_BSB_SOCKET_REG(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_REG(socket) & 0xFF;
	w5500->tx[2] = W5500_Sn_CR | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = W5500_Sn_CR_CLOSE;

	HAL_StatusTypeDef ret = W5500_Transmit(w5500, w5500->tx, 4);

	w5500->used_sockets &= ~(1 << socket);

	return ret;
}

HAL_StatusTypeDef W5500_SetSocketDestIP(W5500_HandleTypeDef * w5500, uint8_t socket, uint8_t * ip) {

	w5500->tx[0] = (W5500_BSB_SOCKET_REG(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_REG(socket) & 0xFF;
	w5500->tx[2] = W5500_Sn_DIPR | W5500_RWB_WRITE | W5500_OPCODE_VDM;

	memcpy(&w5500->tx[3], ip, 4);

	return W5500_Transmit(w5500, w5500->tx, 7);
}

HAL_StatusTypeDef W5500_SetSocketDestPort(W5500_HandleTypeDef * w5500, uint8_t socket, uint16_t port) {

	w5500->tx[0] = (W5500_BSB_SOCKET_REG(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_REG(socket) & 0xFF;
	w5500->tx[2] = W5500_Sn_DPORT | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = (port >> 8) & 0xFF;
	w5500->tx[4] = port & 0xFF;

	return W5500_Transmit(w5500, w5500->tx, 5);
}

HAL_StatusTypeDef W5500_SetSocketDestMAC(W5500_HandleTypeDef * w5500, uint8_t socket, uint8_t * mac) {

	w5500->tx[0] = (W5500_BSB_SOCKET_REG(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_REG(socket) & 0xFF;
	w5500->tx[2] = W5500_Sn_DHAR | W5500_RWB_WRITE | W5500_OPCODE_VDM;

	memcpy(&w5500->tx[3], mac, 6);

	return W5500_Transmit(w5500, w5500->tx, 9);
}

HAL_StatusTypeDef W5500_PrepareSocketData(W5500_HandleTypeDef * w5500, uint8_t socket, uint8_t * data, uint16_t size) {
	w5500->tx[0] = (W5500_BSB_SOCKET_TX(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_TX(socket) & 0xFF;
	w5500->tx[2] = W5500_RWB_WRITE | W5500_OPCODE_VDM;

	memcpy(&w5500->tx[3], data, size);

	return W5500_Transmit(w5500, w5500->tx, 3 + size);
}

HAL_StatusTypeDef W5500_FlushTxBufferInSocketData(W5500_HandleTypeDef * w5500, uint8_t socket, uint16_t size) {
	w5500->tx[0] = (W5500_BSB_SOCKET_TX(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_TX(socket) & 0xFF;
	w5500->tx[2] = W5500_RWB_WRITE | W5500_OPCODE_VDM;

	return W5500_Transmit(w5500, w5500->tx, 3 + size);
}

HAL_StatusTypeDef W5500_SendSocket(W5500_HandleTypeDef * w5500, uint8_t socket, uint8_t * mac = NULL) {
	w5500->tx[0] = (W5500_BSB_SOCKET_REG(socket) >> 8) & 0xFF;
	w5500->tx[1] = W5500_BSB_SOCKET_REG(socket) & 0xFF;
	w5500->tx[2] = W5500_Sn_CR | W5500_RWB_WRITE | W5500_OPCODE_VDM;
	w5500->tx[3] = (mac == NULL ? W5500_Sn_CR_SEND : W5500_Sn_CR_SEND_MAC);

	return W5500_Transmit(w5500, w5500->tx, 4);
}

HAL_StatusTypeDef W5500_DHCPDiscovery(W5500_HandleTypeDef * w5500){
	if (w5500->IP[0] != 0 || w5500->IP[1] != 0 || w5500->IP[2] != 0 || w5500->IP[3] != 0) {
		W5500_SetIP(w5500);
	}
	if (w5500->GATEWAY[0] != 0 || w5500->GATEWAY[1] != 0 || w5500->GATEWAY[2] != 0 || w5500->GATEWAY[3] != 0) {
		W5500_SetGATEWAY(w5500);
	}
	if (w5500->SUBNET[0] != 0 || w5500->SUBNET[1] != 0 || w5500->SUBNET[2] != 0 || w5500->SUBNET[3] != 0) {
		W5500_SetSUBNET(w5500);
	}

	uint8_t socket = W5500_OpenSocket(w5500, W5500_Sn_MR_UDP, DHCP_CLIENT_PORT);

	W5500_SetSocketDestPort(w5500, socket, DHCP_SERVER_PORT);
	uint8_t dest_ip[4] = {255, 255, 255, 255};
	W5500_SetSocketDestIP(w5500, socket, dest_ip);
	uint8_t dest_mac[6] = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};
	W5500_SetSocketDestMAC(w5500, socket, dest_mac);
	memset(&w5500->tx[3], 0, 1024 - 3); // Clear TX buffer

	return W5500_Transmit(w5500, w5500->tx, 3 + W5500_COMMON_SUBR_LEN);
}

HAL_StatusTypeDef W5500_Init(W5500_HandleTypeDef * w5500) {
	W5500_Reset(w5500);
	W5500_ReadVERSIONR(w5500);
	W5500_GenerateMAC(w5500);
	W5500_SetMAC(w5500);
	W5500_ReadMAC(w5500);
	W5500_SetIP(w5500);
	W5500_SetGATEWAY(w5500);
	W5500_SetSUBNET(w5500);
	W5500_PHYReset(w5500);
	return HAL_OK;
}
